{
  "name": "triangular-engine",
  "version": "0.1.0-alpha.1",
  "description": "Angular-first 3D engine powered by Three.js and optional physics engines (Rapier or Jolt) and optional @pmndrs/vanilla helpers. Declarative components for scenes, meshes, materials, lights, GLTF, post-processing, and physics.",
  "keywords": [
    "angular",
    "three",
    "three.js",
    "3d",
    "webgl",
    "gltf",
    "physics",
    "rapier",
    "jolt",
    "engine",
    "components",
    "postprocessing",
    "pmndrs",
    "billboard",
    "sparkles"
  ],
  "type": "module",
  "peerDependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.3",
    "@angular/core": "^20.3.3",
    "three": "^0.183.0",
    "dexie": "^4.2.1",
    "@dimforge/rapier3d-compat": "^0.18.0",
    "jolt-physics": "^1.0.1",
    "@pmndrs/vanilla": "^1.24.0"
  },
  "peerDependenciesMeta": {
    "@dimforge/rapier3d-compat": {
      "optional": true
    },
    "jolt-physics": {
      "optional": true
    },
    "@pmndrs/vanilla": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false
}
